VIRLY_PORT=3000
VIRLY_CLIENT_URL=http://localhost:5173
VIRLY_SERVER_URL=http://localhost:3000
VIRLY_COOKIE_SAME_SITE=lax
VIRLY_MONGODB_URI=mongodb://127.0.0.1:27017/virly
# Repository driver: "mongo" (default) or "postgres". In postgres mode the app
# still connects Mongo (the LangGraph checkpointer/store stay on Mongo — the
# documented Phase-1 hybrid). VIRLY_POSTGRES_URL is required when set to postgres.
VIRLY_DB_DRIVER=mongo
VIRLY_POSTGRES_URL=postgres://virly:virly@localhost:5432/virly
# Where the LangGraph checkpointer + long-term store live (M1.5). Orthogonal to
# VIRLY_DB_DRIVER: "postgres" consolidates AI memory onto the AI Postgres
# (VIRLY_AI_PG_URL); "mongo" (default) keeps it on Mongo. Reversible by env flip.
VIRLY_AI_MEMORY_BACKEND=mongo
VIRLY_JWT_SECRET=long-randopm-number-and-letters
RESEND_API_KEY=
VIRLY_EMAIL_FROM="Virly <verify@virly.ayal.online>"
VIRLY_AI_MOCK_PER_TRANSFER_LIMIT=500
VIRLY_AI_MOCK_DAILY_TRANSFER_LIMIT=1000
VIRLY_AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# --- RAG knowledge base (pgvector) -------------------------------------------
# Dedicated AI-data Postgres for the policy/loan vector store. Independent of
# VIRLY_DB_DRIVER so it works even in mongo mode; falls back to VIRLY_POSTGRES_URL
# when unset. Must have the pgvector extension (use the pgvector/pgvector image).
VIRLY_AI_PG_URL=postgres://virly:virly@localhost:5432/virly
# Turn the searchPolicyDocs tool on. Off by default so the app runs without an AI store.
VIRLY_RAG_ENABLED=false
VIRLY_RAG_EMBEDDING_MODEL=text-embedding-3-small
VIRLY_RAG_TOP_K=5
# Drop retrieved chunks below this cosine similarity (0..1).
VIRLY_RAG_MIN_SCORE=0
# --- Fraud hold-until-email-confirmation (M4) --------------------------------
# Hold transfers at this risk level and above until the sender confirms by email:
# "off" (default, flag only), "high", or "medium". Requires VIRLY_AI_PG_URL.
VIRLY_FRAUD_HOLD_LEVEL=off
VIRLY_FRAUD_HOLD_EXPIRY_HOURS=24
# Ingestion sources (used by `npm run rag:sync`, not at runtime).
# Drive (default source): the folder to sync + a service account with read access.
VIRLY_RAG_DRIVE_FOLDER_ID=
# Provide the service-account key inline as JSON, OR point to a key file:
VIRLY_GOOGLE_SERVICE_ACCOUNT_JSON=
VIRLY_GOOGLE_APPLICATION_CREDENTIALS=
# Local source (alternative): an absolute path to a knowledge-base folder.
VIRLY_RAG_LOCAL_DIR=
# Local demo can use jitsi-public-demo. Production should use jitsi-jaas or jitsi-self-hosted.
VIRLY_VIDEO_PROVIDER=jitsi-public-demo
VIRLY_JITSI_DOMAIN=meet.jit.si
VIRLY_JITSI_APP_ID=
VIRLY_JITSI_AUDIENCE=jitsi
VIRLY_JITSI_ISSUER=
VIRLY_JITSI_SUBJECT=
VIRLY_JITSI_KID=
# Required when VIRLY_VIDEO_PROVIDER is jitsi-jaas or jitsi-self-hosted.
VIRLY_JITSI_PRIVATE_KEY=
VIRLY_JITSI_TOKEN_TTL_SECONDS=900
