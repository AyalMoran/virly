{
  "name": "virly-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx -e \"import('./src/db/postgres.js').then(m => m.runPgMigrations()).then(() => process.exit(0))\"",
    "rag:generate": "drizzle-kit generate --config=drizzle.ai.config.ts",
    "rag:migrate": "tsx -e \"import('./src/db/vector.js').then(m => m.runAiMigrations()).then(() => process.exit(0))\"",
    "rag:sync": "tsx scripts/sync-knowledge-base.ts",
    "eval:policy-rag": "tsx scripts/eval-policy-rag.ts",
    "mcp:support": "tsx scripts/mcp-support-server.ts",
    "fraud:ingest": "tsx scripts/fraud-ingest.ts",
    "test:contract": "tsx --test --test-concurrency=1 \"tests/contract/**/*.test.ts\""
  },
  "dependencies": {
    "@langchain/core": "^1.1.47",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-checkpoint-mongodb": "^1.3.4",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@langchain/openai": "^1.4.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.1",
    "morgan": "^1.10.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "resend": "^6.12.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
