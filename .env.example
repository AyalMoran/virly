# docker-compose.yml reads application settings from server/.env.
# Copy this file to server/.env and fill in the required values.
# See docs/configuration.md for the full reference.

# --- Required in production (server throws at boot if missing or weak) ---
VIRLY_JWT_SECRET=change-me-here-minimum-32-chars-required

# --- Optional: AI agent version (v2 = LLM-first agent; v1 = legacy deterministic) ---
VIRLY_AI_GRAPH_VERSION=v2
