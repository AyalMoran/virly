        "${workspaceFolder}/system_programming/inc",
        "${workspaceFolder}/utils/inc",
        "${workspaceFolder}/projects/watchdog/inc",
    ],
    "c-cpp-flylint.clang.enable": true,
    "c-cpp-flylint.standard": [
        "c89",
        "c++98",
    ],
    "cmake.sourceDirectory": "/home/moranayal/git/ds/SDL_bgi",
    "makefile.makefilePath": "${workspaceFolder}/ds/ds.mk",
    // Disable all automatic formatting for Makefiles
    "[makefile]": {
        "editor.formatOnSave": false,
