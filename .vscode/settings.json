{
    "files.associations": {
        "*.h": "c",
        "cr4tomercalc": "c",
        "functional": "c",
        "cstdlib": "c",
        "typeinfo": "c",
        "random": "c",
        "compare": "c",
        "cstdint": "c",
        "cerrno": "c",
        "string": "c",
        "array": "c",
        "string_view": "c",
        "initializer_list": "c"
    },
    "C_Cpp.default.compilerPath": "/usr/bin/clang-18",
    "C_Cpp.default.intelliSenseMode": "clang-x64",
    "C_Cpp.default.cStandard": "c89",
