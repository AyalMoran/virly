        "${workspaceFolder}/quizzes/inc",
        "${workspaceFolder}/system_programming/inc",
        "${workspaceFolder}/utils/inc",
        "${workspaceFolder}/projects/watchdog/inc",
    ],
    "c-cpp-flylint.cppcheck.executable": "/usr/bin/cppcheck",
    "c-cpp-flylint.cppcheck.extraArgs": [
        "--suppress=variableScope",
        "--suppress=unreadVariable"
    ],
    "c-cpp-flylint.enable": true,
    "c-cpp-flylint.includePaths": [
        "${workspaceFolder}/ds/inc",
        "${workspaceFolder}/algo/inc",
        "${workspaceFolder}/c/inc",
        "${workspaceFolder}/exams/inc",
        "${workspaceFolder}/other/inc",
        "${workspaceFolder}/projects/inc",
